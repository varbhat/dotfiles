# editor
alias v="nvim"
alias ls="eza --icons=auto --hyperlink"

# Colored utilities
alias diff="diff --color=auto"
alias grep="grep --color=auto"
alias ip="ip --color=auto"
#alias ls="ls --color=auto --group-directories-first --hyperlink=auto"

# Navigation aliases
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."

alias cd..="cd .."
alias cd...="cd ../.."
alias cd....="cd ../../.."
alias cd.....="cd ../../../.."

alias home="cd ~"
