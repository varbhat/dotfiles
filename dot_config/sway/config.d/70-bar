# vim: set ft=swayconfig:
bar {
    font pango:"Noto Sans", "Symbols Nerd Font" 9
    position bottom
    status_command i3status-rs
    colors {
        background #000000
        statusline #ffffff
        separator #ccd0da
        focused_workspace #494d64 #494d64 #ffffff
        active_workspace #1e1e2e #1e1e2e #ffffff
        inactive_workspace #1e1e2e #1e1e2e #9ca0b0
        urgent_workspace #900000 #900000 #ffffff
        binding_mode #900000 #900000 #ffffff
    }
}
