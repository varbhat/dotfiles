# vim: set ft=swayconfig:
# Passthrough mode
mode passthrough {
	bindsym $meta+F1 mode default
}
bindsym $meta+F1 mode passthrough

# Workspace Mode
set $workspacemode workspace 
mode "$workspacemode" {
   bindsym {
      1 workspace number 1
      2 workspace number 2
      3 workspace number 3
      4 workspace number 4
      5 workspace number 5
      6 workspace number 6
      7 workspace number 7
      8 workspace number 8
      9 workspace number 9
      0 mode default;exec swaymsg workspace number $dmenu
      Shift+1 move container to workspace number 1
      Shift+2 move container to workspace number 2
      Shift+3 move container to workspace number 3
      Shift+4 move container to workspace number 4
      Shift+5 move container to workspace number 5
      Shift+6 move container to workspace number 6
      Shift+7 move container to workspace number  7
      Shift+8 move container to workspace number 8
      Shift+9 move container to workspace number 9
      Shift+0 mode default;exec swaymsg move container to workspace number $dmenu
      Home workspace prev
      Down exec swaymsg workspace number $(swaymsg -t get_workspaces -r | jq '[.[].num] | min')
      Up exec swaymsg workspace number $(swaymsg -t get_workspaces -r | jq '[.[].num] | max')
      End workspace next
    }
    bindsym Escape mode "default"
}
bindsym $meta+F2 mode "$workspacemode"

# Keyboard layout Mode
set $kblayoutmode keyboard 
mode "$kblayoutmode" {
    set {
        $setkbdvorak exec swaymsg input type:keyboard xkb_variant '""' && swaymsg input type:keyboard xkb_layout '""' && swaymsg input type:keyboard xkb_layout "us" && swaymsg input type:keyboard xkb_variant 'dvorak';
        $setkbqwerty exec swaymsg input type:keyboard xkb_variant '""' && swaymsg input type:keyboard xkb_layout '""' && swaymsg input type:keyboard xkb_layout "us" && swaymsg input type:keyboard xkb_variant 'qwerty';
        $setkbkankagapa exec swaymsg input type:keyboard xkb_variant '""' && swaymsg input type:keyboard xkb_layout '""' && swaymsg input type:keyboard xkb_layout "in" && swaymsg input type:keyboard xkb_variant 'kan-kagapa';
        $setkbsankagapa exec swaymsg input type:keyboard xkb_variant '""' && swaymsg input type:keyboard xkb_layout '""' && swaymsg input type:keyboard xkb_layout "in" && swaymsg input type:keyboard xkb_variant 'san-kagapa';
    }
    # 43 -> dvorak d
    bindcode 43 $setkbdvorak; mode "default" 
    # 53 -> dvorak q
    bindcode 53 $setkbqwerty; mode "default"
    # 55 -> dvorak k
    bindcode 55 $setkbkankagapa; mode "default"
    # 47 -> dvorak s
    bindcode 47 $setkbsankagapa; mode "default"
    bindsym Escape mode "default"
}
